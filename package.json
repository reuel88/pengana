{
	"name": "pengana",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",

		"build": "turbo build",

		"check": "biome check .",
		"check-types": "turbo check-types",
		"check:i18n": "turbo -F @pengana/i18n check:i18n",
		"format": "biome check --write .",

		"db:push": "turbo -F @pengana/db db:push",
		"db:studio": "turbo -F @pengana/db db:studio",
		"db:generate": "turbo -F @pengana/db db:generate",
		"db:migrate": "turbo -F @pengana/db db:migrate",
		"db:start": "turbo -F @pengana/db db:start",
		"db:watch": "turbo -F @pengana/db db:watch",
		"db:stop": "turbo -F @pengana/db db:stop",
		"db:down": "turbo -F @pengana/db db:down",
		"db:destroy": "turbo -F @pengana/db db:destroy",

		"test": "turbo test",
		"e2e": "turbo e2e",
		"e2e:ui": "pnpm --filter @pengana/e2e e2e:ui",

		"prepare": "husky"
	},
	"dependencies": {
		"@pengana/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@pengana/config": "workspace:*",
		"@types/node": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"turbo": "^2.8.15",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "pnpm@10.30.3"
}
