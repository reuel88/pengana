{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@pengana/org-client": ["../org-client/src/index.ts"],
			"@pengana/ui/*": ["./src/*"]
		}
	},
	"include": ["src"]
}
