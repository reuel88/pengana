{
	"name": "@pengana/i18n",
	"type": "module",
	"scripts": {
		"check:i18n": "i18n-check -l src/locales -s en-US -f i18next -o missingKeys invalidKeys"
	},
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./web": {
			"default": "./src/web.ts"
		},
		"./urls": {
			"default": "./src/urls.ts"
		},
		"./native": {
			"default": "./src/native.ts"
		},
		"./extension": {
			"default": "./src/extension.ts"
		},
		"./zod": {
			"default": "./src/zod.ts"
		},
		"./rtl": {
			"default": "./src/rtl.ts"
		},
		"./server": {
			"default": "./src/server.ts"
		},
		"./config": {
			"default": "./src/config.ts"
		}
	},
	"dependencies": {
		"i18next": "^25.8.17",
		"i18next-browser-languagedetector": "^8.0.5",
		"i18next-resources-to-backend": "^1.2.1",
		"react-i18next": "^16.5.6"
	},
	"peerDependencies": {
		"react": ">=18",
		"zod": ">=3"
	},
	"devDependencies": {
		"@lingual/i18n-check": "^0.9.1",
		"@pengana/config": "workspace:*",
		"typescript": "catalog:"
	}
}
