{
	"name": "@pengana/org-client",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./types": {
			"default": "./src/types/index.ts"
		},
		"./lib/*": {
			"default": "./src/lib/*.ts"
		},
