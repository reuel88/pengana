{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.mjs"
	},
	"dependencies": {
		"@pengana/api": "workspace:*",
		"@pengana/auth": "workspace:*",
		"@pengana/i18n": "workspace:*",
		"@pengana/db": "workspace:*",
		"@pengana/env": "workspace:*",
		"@hono/node-server": "^1.14.4",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"ws": "^8.18.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@pengana/config": "workspace:*",
		"@types/node": "catalog:",
		"@types/ws": "^8.18.0",
		"tsdown": "^0.16.5",
		"tsx": "^4.19.2",
		"typescript": "catalog:"
	}
}
