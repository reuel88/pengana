NODE_ENV=development

BETTER_AUTH_SECRET=your-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
# Comma-separated allowed web origins for CORS, for example http://localhost:3001.
ENABLE_EMAIL_DEV=false
# Boolean flag for exposing the local email preview UI; keep false in production.
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_PRO_PRODUCT_ID=c69d9ab1-4e67-4a0c-8ff5-364a94e536f0
# Polar product UUID for the paid plan; replace with your real product ID.
POLAR_PRO_PRODUCT_SLUG=pro
# Product slug used in checkout URLs, typically lowercase and hyphen-safe.
POLAR_SERVER=sandbox
# Polar environment: use sandbox for local/dev and production for live billing.
POLAR_SUCCESS_URL=http://localhost:3001/success?checkout_id={CHECKOUT_ID}
# Checkout return URL; include the literal {CHECKOUT_ID} placeholder.
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
# Secret from Polar webhook settings; rotate if exposed.
WEB_URL=http://localhost:3001
# Canonical web app URL used in emails; change this for production.

DATABASE_URL=postgresql://postgres:password@localhost:5432/pengana

FREE_TIER_SEATS=2
